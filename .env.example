# Backend env (server/index.mjs)
PORT="8787"
HOST="0.0.0.0"
QWEN_API_KEY="YOUR_QWEN_API_KEY"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen3.5-plus"
# Single Qwen request timeout (ms), e.g. 120000 = 120s
QWEN_REQUEST_TIMEOUT_MS="120000"
# Full /api/analyze timeout (ms), should be <= nginx proxy_read_timeout
ANALYZE_TIMEOUT_MS="240000"
# Output token cap per Qwen request. Lower value = faster response.
QWEN_MAX_TOKENS="1400"
# Whether to enable model deep-thinking. true is slower.
QWEN_ENABLE_THINKING="false"
# Sections limit to control latency and payload size.
VISUAL_SECTION_LIMIT="4"
STRATEGIC_SECTION_LIMIT="4"
# Fast mode for /api/analyze
ANALYZE_FAST_MODE="true"
ANALYZE_FAST_MAX_TOKENS="450"
ANALYZE_FAST_VISUAL_SECTION_LIMIT="2"
ANALYZE_FAST_STRATEGIC_SECTION_LIMIT="2"

# MemFire (server only: never put service_role in iOS/Web)
MEMFIRE_URL="https://<project-ref>.memfiredb.com"
MEMFIRE_SERVICE_ROLE_KEY="YOUR_MEMFIRE_SERVICE_ROLE_KEY"
MEMFIRE_ANON_KEY="YOUR_MEMFIRE_ANON_KEY"
# Optional: if set, all /api/memfire/admin/* routes require x-admin-token
MEMFIRE_ADMIN_TOKEN=""

# Frontend dev proxy target (vite dev server -> backend)
API_BASE_URL="http://127.0.0.1:8787"

# Built app API base URL (must set for iOS/Android native builds)
# Example (simulator on same Mac): http://127.0.0.1:8787
# Example (real iPhone on LAN):    http://<your-mac-lan-ip>:8787
# Example (public ECS server):      http://39.106.79.115
VITE_API_BASE_URL="http://127.0.0.1:8787"
